  <repositories>
    <repository>
      <id>central</id>
      <url>https://repo1.maven.org/maven2/</url>
      <releases>
        <updatePolicy>never</updatePolicy>
    </releases>
    <snapshots>
      <updatePolicy>never</updatePolicy>
    </snapshots>
    </repository>
  </repositories>

